{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.dev/vince-skill-engineer/build-report.schema.json",
  "title": "vince-skill-engineer build report",
  "description": "Emitted by vince-skill-engineer after building+testing a skill; consumed by vince-skill-zipper (or the user).",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_by", "target", "source_spec", "altitude", "built", "tests", "actions_resolved", "verification", "handoff"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "generated_by": {"const": "vince-skill-engineer"},
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "name"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "name": {"type": "string", "minLength": 1}
      }
    },
    "source_spec": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["path"],
      "properties": {"path": {"type": "string"}}
    },
    "altitude": {"enum": ["lite", "full"]},
    "built": {
      "type": "object",
      "additionalProperties": false,
      "required": ["design_units", "files_created", "files_modified"],
      "properties": {
        "design_units": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["unit", "status"],
            "properties": {
              "unit": {"enum": ["trigger", "protocol", "resources", "evidence_base", "controls", "tests", "metrics", "lifecycle"]},
              "status": {"enum": ["implemented", "minimal", "na"]},
              "files": {"type": "array", "items": {"type": "string"}},
              "note": {"type": "string"}
            }
          }
        },
        "files_created": {"type": "array", "items": {"type": "string"}},
        "files_modified": {"type": "array", "items": {"type": "string"}}
      }
    },
    "tests": {
      "type": "object",
      "additionalProperties": false,
      "required": ["eval_cases", "totals", "trajectory_checked"],
      "properties": {
        "eval_cases": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["id", "name", "passed"],
            "properties": {
              "id": {"type": "string"},
              "name": {"type": "string"},
              "passed": {"type": "boolean"},
              "evidence": {"type": "string"}
            }
          }
        },
        "totals": {
          "type": "object",
          "additionalProperties": false,
          "required": ["passed", "failed", "total"],
          "properties": {
            "passed": {"type": "integer", "minimum": 0},
            "failed": {"type": "integer", "minimum": 0},
            "total": {"type": "integer", "minimum": 0}
          }
        },
        "regression_cases": {"type": "array", "items": {"type": "string"}},
        "trajectory_checked": {"type": "boolean"}
      }
    },
    "actions_resolved": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "status"],
        "properties": {
          "id": {"type": "string"},
          "status": {"enum": ["done", "deferred", "blocked"]},
          "note": {"type": "string"}
        }
      }
    },
    "verification": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ran", "all_required_passed", "evidence"],
      "properties": {
        "ran": {"type": "boolean"},
        "all_required_passed": {"type": "boolean"},
        "evidence": {"type": "string"}
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["next_skill", "notes", "blocking"],
      "properties": {
        "next_skill": {"const": "vince-skill-zipper"},
        "notes": {"type": "array", "items": {"type": "string"}},
        "blocking": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}

  "schema_version": "1.0.0",
  "library_id": "loop-principle",
  "title_zh": "Loop Engineering 原则知识库",
  "title_en": "Loop Engineering Principle Knowledge Base",
  "purpose_zh": "为研究和设计 agent 工作循环（loop engineering）的人和 agent 提供低上下文、可检索、可溯源、可自验证的中立调研知识库：如何设计、修改、更新并保证一个循环工程好用。",
  "purpose_en": "An agent-first, low-context, searchable, source-traceable, self-validating neutral survey of loop engineering — how to design, modify, update, and ensure an agentic work-loop is sound.",
  "root_definition": {
    "id": "concept.loop_engineering",
    "summary_zh": "Loop engineering 是设计一个替你给 agent 发提示的系统——发现任务、分配、检查结果、记录状态、决定下一步——而不是人逐轮提示。其内核是验证工程。",
    "summary_en": "Loop engineering is designing the system that prompts the agent — discovering work, dispatching it, checking results, recording state, deciding the next step — instead of a human prompting turn-by-turn. At its core it is verification engineering."
  },

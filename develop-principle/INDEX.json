{
  "schema_version": "1.0.0",
  "library_id": "develop-principle",
  "title_zh": "工业级 Skill 开发原则知识库",
  "title_en": "Industrial Skill Development Principle Knowledge Base",
  "purpose_zh": "为开发 skill 的 agent 提供低上下文消耗、可检索、可测试、可量化的工程化理论和执行资产。",
  "purpose_en": "Provides agent-first, low-context, searchable, testable, and measurable engineering knowledge for industrial skill development.",
  "root_definition": {
    "id": "concept.skill",
    "summary_zh": "Skill 是面向 agent 的可复用能力包，包含触发条件、行为协议、支撑材料、控制边界、测试资产、量化指标和生命周期规则。",
    "summary_en": "A skill is a reusable agent capability package containing trigger rules, behavior protocol, supporting materials, control boundaries, test assets, quantitative metrics, and lifecycle rules."
  },
  "coverage": [
    {
      "goal_id": "goal.industrial_design",
      "title_zh": "工业级 skill 的设计思路和标准",
      "primary_docs": ["doc.architecture.industrial_skill_design"],
      "primary_nodes": ["pillar.design", "principle.progressive_disclosure", "principle.executable_acceptance", "anti_pattern.prompted_architecture"]

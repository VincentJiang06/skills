{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.dev/develop-principle/schemas/eval_case.schema.json",
  "title": "Skill Eval Case",
  "type": "object",
  "required": ["id", "skill_id", "case_type", "task_zh", "task_en", "initial_state", "acceptance_criteria", "graders", "expected_activation", "expected_trajectory", "budgets"],
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string"},
    "skill_id": {"type": "string"},
    "case_type": {"type": "string", "enum": ["happy_path", "boundary", "negative", "adjacent", "adversarial", "regression"]},
    "task_zh": {"type": "string"},
    "task_en": {"type": "string"},
    "initial_state": {"type": "object"},
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
    "graders": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type", "description"],
        "properties": {
          "id": {"type": "string"},
          "type": {"type": "string", "enum": ["deterministic", "trajectory", "llm_judge", "human_review"]},
          "description": {"type": "string"}
        }
      }
    },
    "expected_activation": {"type": "string", "enum": ["must_activate", "must_not_activate", "optional"]},
    "expected_trajectory": {"type": "object"},
    "budgets": {"type": "object"}
  }
}

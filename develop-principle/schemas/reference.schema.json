{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.dev/develop-principle/schemas/reference.schema.json",
  "title": "Develop Principle Reference Entry",
  "type": "object",
  "required": ["id", "tier", "title_en", "title_zh", "authors_or_org", "source_type", "url", "summary_zh", "summary_en", "reuse_notes", "reliability_notes"],
  "additionalProperties": false,
  "properties": {
    "id": {"type": "string", "pattern": "^ref\\.[a-z0-9_\\.]+$"},
    "tier": {"type": "integer", "minimum": 1, "maximum": 4},
    "title_en": {"type": "string", "minLength": 1},
    "title_zh": {"type": "string", "minLength": 1},
    "authors_or_org": {"type": "string", "minLength": 1},
    "source_type": {"type": "string", "minLength": 1},
    "url": {"type": "string", "format": "uri"},
    "summary_zh": {"type": "string", "minLength": 1},
    "summary_en": {"type": "string", "minLength": 1},
    "reuse_notes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "reliability_notes": {"type": "string", "minLength": 1}
  }
}

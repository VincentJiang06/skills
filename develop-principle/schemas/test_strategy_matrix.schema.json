{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.dev/develop-principle/schemas/test_strategy_matrix.schema.json",
  "title": "Develop Principle Test Strategy Matrix",
  "type": "object",
  "required": ["schema_version", "matrix_id", "title_zh", "title_en", "levels", "reference_ids"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string"},
    "matrix_id": {"type": "string"},
    "title_zh": {"type": "string"},
    "title_en": {"type": "string"},
    "levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["level", "name", "goal_zh", "goal_en", "typical_checks"],
        "additionalProperties": false,
        "properties": {
          "level": {"type": "string"},
          "name": {"type": "string"},
          "goal_zh": {"type": "string"},
          "goal_en": {"type": "string"},
          "typical_checks": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        }
      }
    },
    "reference_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  }
}

{
  "schema_version": "1.0.0",
  "suite_id": "query_effectiveness.skill_design_requirements",
  "purpose": "Validate that develop-principle can route realistic skill-design requirements to relevant docs, graph nodes, and execution assets through public indexes.",
  "cases": [
    {
      "id": "query.skill_package_architecture",
      "requirement": "我要设计一个通用 agent skill，先确认 skill package 的边界、trigger、execution protocol 和 supporting resources。",
      "expected_doc_ids": ["doc.architecture.industrial_skill_design"],
      "expected_node_ids": ["concept.skill", "concept.trigger", "concept.execution_protocol"],
      "expected_asset_ids": ["template.skill_design_record"]
    },
    {
      "id": "query.progressive_disclosure",
      "requirement": "这个 skill 入口太长，需要 progressive disclosure 和低上下文加载策略。",
      "expected_doc_ids": ["doc.operations.knowledge_base_architecture", "doc.architecture.industrial_skill_design"],
      "expected_node_ids": ["principle.progressive_disclosure", "principle.short_node_budget", "pattern.progressive_loading"],
      "expected_asset_ids": ["decision.0001"]
    },
    {
      "id": "query.activation_routing",
      "requirement": "我要测试 skill 什么时候应该触发，什么时候不该触发，尤其是 adjacent false trigger。",
      "expected_doc_ids": ["doc.metrics.quantitative_skill_metrics", "doc.testing.skill_testing_process"],
      "expected_node_ids": ["concept.trigger", "metric.activation_precision", "metric.false_positive_rate"],
      "expected_asset_ids": ["testing.strategy_matrix"]
    },
    {
      "id": "query.tdd_red_green",
      "requirement": "请为一个新 skill 做 TDD red green refactor 规划，先写失败 eval case 再实现。",
      "expected_doc_ids": ["doc.testing.tdd_for_skill_development"],
      "expected_node_ids": ["pillar.tdd", "procedure.red_green_refactor_for_skill"],
      "expected_asset_ids": ["template.tdd_plan", "testing.tdd_workflow"]
    },
    {
      "id": "query.eval_case_template",
      "requirement": "我需要一个 eval case 模板，包含 task prompt、acceptance criteria、trajectory assertions 和 deterministic verifier。",
      "expected_doc_ids": ["doc.testing.skill_testing_process", "doc.testing.tdd_for_skill_development"],
      "expected_node_ids": ["concept.test_asset", "procedure.trajectory_eval"],
      "expected_asset_ids": ["template.eval_case", "schema.eval_case", "template.trajectory_assertion"]
    },
    {
      "id": "query.template_contracts",
      "requirement": "我要检查 template 是否包含工业化 agent 需要的 required paths、数组字段、metric ids、reference ids 和枚举占位。",
      "expected_doc_ids": ["doc.testing.skill_testing_process"],
      "expected_node_ids": ["concept.test_asset", "principle.executable_acceptance"],
      "expected_asset_ids": ["testing.template_contracts", "schema.template_contracts", "tool.validate_kb"]
    },
    {
      "id": "query.research_doc_template",
      "requirement": "我要写调研文档，要求来源证据、findings、inferences、decisions、asset updates、validation plan 和 AI 写作约束。",
      "max_expected_total_ids": 14,
      "expected_doc_ids": ["doc.research.evidence_driven_skill_research", "doc.operations.knowledge_base_architecture"],
      "expected_node_ids": ["pillar.kb_architecture", "principle.id_references", "pattern.progressive_loading"],
      "expected_asset_ids": ["template.research_doc", "checklist.research_doc_quality"]
    },
    {
      "id": "query.trajectory_eval",
      "requirement": "这个 skill 不能只看最终输出，我想评估 tool calls、arguments、loaded docs 和 state changes。",
      "expected_doc_ids": ["doc.testing.skill_testing_process"],
      "expected_node_ids": ["procedure.trajectory_eval", "metric.tool_call_correctness", "metric.progress_rate"],
      "expected_asset_ids": ["template.trajectory_assertion"]
    },
    {
      "id": "query.paired_eval",
      "requirement": "怎么比较 with-skill vs without-skill，判断这个 skill 是否真的有 marginal lift？",
      "expected_doc_ids": ["doc.testing.skill_testing_process", "doc.metrics.quantitative_skill_metrics"],
      "expected_node_ids": ["procedure.paired_skill_eval", "metric.marginal_lift", "metric.cost_per_success"],
      "expected_asset_ids": ["template.metric_plan"]
    },
    {
      "id": "query.metric_catalog",
      "requirement": "我要量化 skill 的 success rate、pass^k、cost per success、loaded context tokens。",
      "expected_doc_ids": ["doc.metrics.quantitative_skill_metrics"],
      "expected_node_ids": ["metric.task_success_rate", "metric.pass_k", "metric.cost_per_success"],
      "expected_asset_ids": ["metrics.catalog"]
    },
    {
      "id": "query.regression_suite",
      "requirement": "生产失败样例要进入 regression suite，并在每次 skill 改动后重跑。",
      "expected_doc_ids": ["doc.testing.skill_testing_process", "doc.operations.skill_lifecycle_management"],
      "expected_node_ids": ["procedure.regression_suite", "metric.regression_escape_rate", "procedure.production_feedback_loop"],
      "expected_asset_ids": ["testing.strategy_matrix"]
    },
    {
      "id": "query.contract_test",
      "requirement": "我需要测试 skill 的 output schema、allowed paths、tool arguments 和 error contract。",
      "expected_doc_ids": ["doc.testing.tdd_for_skill_development"],
      "expected_node_ids": ["technique.contract_test", "principle.executable_acceptance"],
      "expected_asset_ids": ["schema.eval_case", "template.trajectory_assertion"]
    },
    {
      "id": "query.mutation_test",
      "requirement": "如何故意破坏 skill 的边界、步骤和示例，看看测试套件能不能抓住退化？",
      "expected_doc_ids": ["doc.testing.tdd_for_skill_development", "doc.metrics.quantitative_skill_metrics"],
      "expected_node_ids": ["technique.mutation_test", "metric.mutation_score"],
      "expected_asset_ids": ["metrics.catalog"]
    },
    {
      "id": "query.metamorphic_test",
      "requirement": "开放式 skill 没有唯一正确答案，我想用 metamorphic testing 检查输入变换前后的关系。",
      "expected_doc_ids": ["doc.testing.tdd_for_skill_development"],
      "expected_node_ids": ["technique.metamorphic_test"],
      "expected_asset_ids": ["template.eval_case"]
    },
    {
      "id": "query.release_gate",
      "requirement": "skill 发布前要做 release gate，检查结构、回归、成本、控制边界和 rollback。",
      "expected_doc_ids": ["doc.operations.skill_lifecycle_management", "doc.operations.skill_lifecycle_governance"],
      "expected_node_ids": ["pillar.lifecycle", "procedure.release_gate", "procedure.rollback_plan"],
      "expected_asset_ids": ["checklist.skill_release_gate", "template.skill_release_manifest"]
    },
    {
      "id": "query.registry_version",
      "requirement": "我想管理 skill registry、semantic versioning、immutable releases 和 package manifest。",
      "expected_doc_ids": ["doc.operations.skill_lifecycle_management"],
      "expected_node_ids": ["pattern.skill_registry", "concept.skill_release_manifest"],
      "expected_asset_ids": ["template.skill_release_manifest"]
    },
    {
      "id": "query.deprecation",
      "requirement": "旧 skill 要 deprecated，提供 replacement、sunset date 和 migration path。",
      "expected_doc_ids": ["doc.operations.skill_lifecycle_management"],
      "expected_node_ids": ["procedure.deprecation_policy", "procedure.skill_deprecation"],
      "expected_asset_ids": ["template.deprecation_notice"]
    },
    {
      "id": "query.observability",
      "requirement": "我要记录 skill runtime trace，包括 agent span、tool span、guardrail event 和 lifecycle trace coverage。",
      "expected_doc_ids": ["doc.operations.skill_lifecycle_management", "doc.metrics.quantitative_skill_metrics"],
      "expected_node_ids": ["metric.lifecycle_trace_coverage", "procedure.production_feedback_loop"],
      "expected_asset_ids": ["template.release_report"]
    },
    {
      "id": "query.security_boundary",
      "requirement": "这个 skill 会调用危险工具，需要检查 allowed tools、forbidden tools、network policy 和 human gate。",
      "expected_doc_ids": ["doc.architecture.industrial_skill_design", "doc.operations.skill_lifecycle_governance"],
      "expected_node_ids": ["pillar.lifecycle", "procedure.release_gate"],
      "expected_asset_ids": ["checklist.security_boundary", "template.skill_design_record"]
    },
    {
      "id": "query.anti_pattern",
      "requirement": "我担心把权限、安全和验收都塞进长 prompt，想找相关 anti pattern 和替代方案。",
      "expected_doc_ids": ["doc.architecture.industrial_skill_design"],
      "expected_node_ids": ["anti_pattern.prompted_architecture", "principle.executable_acceptance"],
      "expected_asset_ids": ["checklist.skill_design_review"]
    },
    {
      "id": "query.documentation_structure",
      "requirement": "我要给 agent 使用的文档库做短入口、ID 引用、知识图谱节点和 Markdown 长文分离。",
      "expected_doc_ids": ["doc.operations.knowledge_base_architecture", "doc.operations.local_retrieval_workflow"],
      "expected_node_ids": ["pillar.kb_architecture", "principle.id_references", "principle.short_node_budget"],
      "expected_asset_ids": ["tool.validate_kb"]
    },
    {
      "id": "query.local_retrieval_quality",
      "requirement": "本地 agent 数据库要用生成索引查询，并输出质量报告、coverage gate 和图谱邻接检查。",
      "expected_doc_ids": ["doc.operations.local_retrieval_workflow", "doc.operations.knowledge_base_architecture"],
      "expected_node_ids": ["pillar.kb_architecture", "pattern.progressive_loading"],
      "expected_asset_ids": ["tool.query_kb", "tool.generate_quality_report", "report.kb_quality", "testing.kb_quality_gates", "index.graph_adjacency"]
    },
    {
      "id": "query.agent_principle_scaffold",
      "requirement": "我要给一个本地 agent 项目生成 AGENT.md 和简单 CLI，让它用 develop-principle 做 plan、query 和 audit。",
      "expected_doc_ids": ["doc.operations.local_retrieval_workflow", "doc.operations.knowledge_base_architecture"],
      "expected_node_ids": ["pillar.kb_architecture", "pattern.progressive_loading"],
      "expected_asset_ids": ["tool.scaffold_agent_principle", "tool.query_kb", "tool.run_all_checks"]
    },
    {
      "id": "query.quality_audit_report",
      "requirement": "提交前我要看知识库质量审计报告，确认 quality gates、required gate summary、coverage 和 schema 都可靠。",
      "expected_doc_ids": ["doc.operations.knowledge_base_architecture"],
      "expected_node_ids": ["pillar.kb_architecture", "pattern.progressive_loading"],
      "expected_asset_ids": ["report.kb_quality", "schema.quality_report", "testing.kb_quality_gates", "tool.generate_quality_report"]
    },
    {
      "id": "query.summary_card_precommit",
      "requirement": "本地知识库要保留压缩结论卡片，提交前检查 summary cards 是否覆盖长文和节点。",
      "expected_doc_ids": ["doc.operations.local_retrieval_workflow", "doc.operations.knowledge_base_architecture"],
      "expected_node_ids": ["pillar.kb_architecture", "principle.short_node_budget", "pattern.progressive_loading"],
      "expected_asset_ids": ["index.summary_cards", "schema.summary_cards", "tool.run_all_checks", "report.kb_quality"]
    },
    {
      "id": "query.full_review",
      "requirement": "请审查一个 skill 是否工业级：设计、测试、TDD、指标、生命周期和低上下文都要覆盖。",
      "max_expected_total_ids": 18,
      "expected_doc_ids": [
        "doc.architecture.industrial_skill_design",
        "doc.testing.skill_testing_process",
        "doc.testing.tdd_for_skill_development",
        "doc.metrics.quantitative_skill_metrics",
        "doc.operations.skill_lifecycle_management",
        "doc.operations.knowledge_base_architecture"
      ],
      "expected_node_ids": ["pillar.design", "pillar.testing", "pillar.tdd", "pillar.metrics", "pillar.lifecycle", "pillar.kb_architecture"],
      "expected_asset_ids": ["checklist.skill_design_review", "checklist.skill_release_gate", "metrics.catalog"]
    },
    {
      "id": "query.research_collection",
      "requirement": "依赖外部事实的 skill 要做资料搜集：来源花名册、多角度广度 fan-out、迭代深度、可靠性分级、三角验证，每条结论可溯源到证据。",
      "expected_doc_ids": ["doc.research.evidence_driven_skill_research"],
      "expected_node_ids": ["pillar.research", "procedure.source_roster", "procedure.search_fan_out"],
      "expected_asset_ids": ["template.research_doc"]
    }
  ]
}

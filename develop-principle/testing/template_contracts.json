{
  "schema_version": "1.0.0",
  "contract_set_id": "testing.template_contracts",
  "purpose": "Semantic contracts for JSON templates used by industrial agent skill development workflows.",
  "contracts": [
    {
      "template_id": "template.deprecation_notice",
      "required_paths": ["skill_id", "version_range", "deprecated_at", "sunset_at", "replacement_id", "replacement_version", "severity", "reason_zh", "reason_en", "migration_steps", "compatibility_notes", "owner", "reference_ids"],
      "array_paths": ["migration_steps", "compatibility_notes", "reference_ids"],
      "reference_id_paths": ["reference_ids"],
      "metric_id_paths": [],
      "file_id_paths": [],
      "enum_paths": [{"path": "severity", "values": ["info|warning|error"]}]
    },
    {
      "template_id": "template.eval_case",
      "required_paths": ["id", "skill_id", "case_type", "task_zh", "task_en", "initial_state.workspace", "initial_state.fixtures", "initial_state.permissions", "initial_state.model", "initial_state.skill_version", "acceptance_criteria", "graders", "expected_activation", "expected_trajectory.match_mode", "expected_trajectory.required_events", "budgets.max_trials"],
      "array_paths": ["initial_state.fixtures", "initial_state.permissions", "acceptance_criteria", "graders", "expected_trajectory.required_events"],
      "reference_id_paths": [],
      "metric_id_paths": [],
      "file_id_paths": [],
      "enum_paths": [
        {"path": "case_type", "values": ["happy_path"]},
        {"path": "expected_activation", "values": ["must_activate"]},
        {"path": "expected_trajectory.match_mode", "values": ["subset"]}
      ]
    },
    {
      "template_id": "template.metric_plan",
      "required_paths": ["metric_plan_id", "skill_id", "baseline.without_skill_run_id", "baseline.old_skill_run_id", "candidate.with_skill_run_id", "candidate.new_skill_version", "required_metrics", "trial_policy.repeat_count", "trial_policy.isolate_trials", "trial_policy.stable_environment_required", "decision_thresholds"],
      "array_paths": ["required_metrics"],
      "reference_id_paths": [],
      "metric_id_paths": ["required_metrics"],
      "file_id_paths": [],
      "enum_paths": []
    },
    {
      "template_id": "template.metric_record",
      "required_paths": ["metric.id", "metric.title_zh", "metric.title_en", "metric.group", "metric.definition_zh", "metric.definition_en", "metric.formula", "metric.unit", "metric.direction", "metric.required_inputs", "metric.recommended_thresholds", "metric.known_failure_modes", "metric.reference_ids"],
      "array_paths": ["metric.required_inputs", "metric.known_failure_modes", "metric.reference_ids"],
      "reference_id_paths": ["metric.reference_ids"],
      "metric_id_paths": [],
      "file_id_paths": [],
      "enum_paths": [
        {"path": "metric.group", "values": ["effectiveness"]},
        {"path": "metric.direction", "values": ["higher_is_better"]}
      ]
    },
    {
      "template_id": "template.skill_design_record",
      "required_paths": ["skill_id", "name_zh", "name_en", "target_users", "problem_statement_zh", "problem_statement_en", "trigger.must_activate_on", "trigger.must_not_activate_on", "trigger.adjacent_confusions", "trigger.manual_activation_phrases", "execution_protocol.preflight", "execution_protocol.steps", "execution_protocol.verification", "execution_protocol.reporting", "execution_protocol.failure_paths", "resources.docs", "resources.templates", "resources.scripts", "resources.fixtures", "control_boundaries.allowed_tools", "control_boundaries.forbidden_tools", "control_boundaries.allowed_paths", "control_boundaries.human_gate_conditions", "test_assets.eval_case_ids", "test_assets.fixture_paths", "test_assets.trajectory_assertions", "metric_plan_id", "reference_ids"],
      "array_paths": ["target_users", "trigger.must_activate_on", "trigger.must_not_activate_on", "trigger.adjacent_confusions", "trigger.manual_activation_phrases", "execution_protocol.preflight", "execution_protocol.steps", "execution_protocol.verification", "execution_protocol.reporting", "execution_protocol.failure_paths", "resources.docs", "resources.templates", "resources.scripts", "resources.fixtures", "control_boundaries.allowed_tools", "control_boundaries.forbidden_tools", "control_boundaries.allowed_paths", "control_boundaries.human_gate_conditions", "test_assets.eval_case_ids", "test_assets.fixture_paths", "test_assets.trajectory_assertions", "reference_ids"],
      "reference_id_paths": ["reference_ids"],
      "metric_id_paths": [],
      "file_id_paths": ["resources.docs", "resources.templates"],
      "enum_paths": []
    },
    {
      "template_id": "template.skill_release_manifest",
      "required_paths": ["skill.id", "skill.name", "skill.version", "skill.owner", "skill.source_uri", "skill.artifact_uri", "skill.checksum", "skill.compatibility", "change.change_type", "change.summary_zh", "change.summary_en", "change.breaking_change", "change.public_behavior_contract_changed", "change.changelog_path", "release_gate.checklist_id", "release_gate.passed", "release_gate.failed_check_ids", "release_gate.waived_check_ids", "release_gate.evidence_paths", "tests.eval_suite_id", "tests.regression_suite_id", "cost.entry_tokens", "observability.trace_schema_version", "observability.required_event_fields", "observability.dashboard_uri", "rollback.known_good_version", "rollback.rollback_trigger", "rollback.rollback_steps_path", "rollback.validation_after_rollback", "deprecation.deprecated"],
      "array_paths": ["skill.compatibility", "release_gate.failed_check_ids", "release_gate.waived_check_ids", "release_gate.evidence_paths", "observability.required_event_fields", "rollback.rollback_trigger", "rollback.validation_after_rollback"],
      "reference_id_paths": [],
      "metric_id_paths": [],
      "file_id_paths": [],
      "enum_paths": [{"path": "change.change_type", "values": ["patch|minor|major|prerelease"]}]
    },
    {
      "template_id": "template.trajectory_assertion",
      "required_paths": ["assertion.id", "assertion.assertion_type", "assertion.title_zh", "assertion.title_en", "assertion.match_mode", "assertion.target.tool_name", "assertion.target.arguments", "assertion.target.loaded_doc_ids", "assertion.target.forbidden_tool_names", "assertion.failure_message", "assertion.reference_ids"],
      "array_paths": ["assertion.target.loaded_doc_ids", "assertion.target.forbidden_tool_names", "assertion.reference_ids"],
      "reference_id_paths": ["assertion.reference_ids"],
      "metric_id_paths": [],
      "file_id_paths": ["assertion.target.loaded_doc_ids"],
      "enum_paths": [
        {"path": "assertion.assertion_type", "values": ["must_call_tool"]},
        {"path": "assertion.match_mode", "values": ["subset"]}
      ]
    }
  ]
}

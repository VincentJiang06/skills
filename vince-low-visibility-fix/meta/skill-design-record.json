{
  "schema_version": "1.0.0",
  "template_id": "template.skill_design_record",
  "skill_id": "skill.vince-low-visibility-fix",
  "name_zh": "现场低能见度 UI 审计与修复",
  "name_en": "Low-Visibility UI Fix",
  "target_users": ["agent_developer", "frontend_engineer", "field_app_maintainer"],
  "problem_statement_zh": "让 agent 审计并在确认后修复现有移动端 HTML/CSS，使其在现场低能见度条件（暗光/眩光 + 手套/湿手/震动）下可读可操作，关键判定由确定性脚本而非纯模型推理给出。",
  "problem_statement_en": "Enable agents to audit and, after confirmation, fix existing mobile HTML/CSS for field low-visibility conditions (low-light/glare + gloves/wet/vibration), with core checks made by a deterministic script rather than model-only judgment.",
  "trigger": {
    "must_activate_on": [
      "audit existing mobile UI for field low-visibility usability",
      "fix contrast / touch-target / color-only / icon-only issues in HTML/CSS",
      "make an existing UI usable outdoors / in low light / with gloves"
    ],
    "must_not_activate_on": [
      "designing a new UI from scratch",
      "disability or screen-reader accessibility (colorblind, low-vision)",
      "generic CSS review with no low-visibility angle"
    ],
    "adjacent_confusions": [
      "design a new field worker UI (design, not fix)",
      "make it accessible for blind users (a11y populations, out of scope)",
      "prettify CSS with no field angle"
    ],
    "manual_activation_phrases": ["$vince-low-visibility-fix", "audit this for field/low-light"]
  },
  "execution_protocol": {
    "preflight": [
      "confirm field low-visibility audit/fix scope",
      "locate HTML/CSS or detect screenshot-only",
      "load design-tokens.json",
      "determine rollback capability (git or .lv-backup)"
    ],
    "steps": [
      "run analyze.py",
      "complete needs_judgment items by reasoning",
      "present prioritized plan and wait for approval",
      "snapshot then apply gated fixes",
      "re-run analyzer with --compare",
      "report before/after"
    ],
    "verification": [
      "analyzer score and findings",
      "comparison.fixed covers approved findings",
      "comparison.introduced empty",
      "evals/check.py golden suite passes"
    ],
    "reporting": [
      "summarize findings by severity",
      "state edits and rollback command",
      "list residual needs_judgment"
    ],
    "failure_paths": [
      "PATH_OUTSIDE_TARGET",
      "NO_ROLLBACK_AVAILABLE",
      "ANALYZER_INPUT_NOT_HTML",
      "SCREENSHOT_ONLY_DEGRADED"
    ]
  },
  "resources": {
    "docs": ["rules/audit-protocol.md", "rules/fix-patterns.md", "references/field-conditions.md", "references/research-bibliography.md"],
    "templates": [],
    "scripts": ["scripts/analyze.py", "evals/run_all.py", "evals/check.py", "evals/schema_check.py"],
    "fixtures": [
      "evals/fixtures/bad_field_ui.html",
      "evals/fixtures/needs_judgment.html",
      "evals/fixtures/clean_field_ui.html"
    ]
  },
  "control_boundaries": {
    "allowed_tools": ["Read", "Edit", "Write (target UI files only)", "Bash (run analyzer)"],
    "forbidden_tools": ["network access"],
    "allowed_paths": ["the user-provided target path and its directory"],
    "human_gate_conditions": ["any file edit"],
    "cost_budget": null,
    "context_budget_tokens": 6000
  },
  "test_assets": {
    "eval_case_ids": [
      "eval.lvuifix.audit_happy_bad_field_ui",
      "eval.lvuifix.fix_and_verify",
      "eval.lvuifix.partial_css_vars",
      "eval.lvuifix.screenshot_only",
      "eval.lvuifix.negative_new_design",
      "eval.lvuifix.negative_screenreader_a11y",
      "eval.lvuifix.adversarial_lower_contrast",
      "eval.lvuifix.adversarial_path_escape"
    ],
    "fixture_paths": [
      "evals/fixtures/bad_field_ui.html",
      "evals/fixtures/needs_judgment.html",
      "evals/fixtures/clean_field_ui.html"
    ],
    "trajectory_assertions": [
      "analyzer runs before any edit",
      "no file edit before the plan gate",
      "writes stay within the target directory",
      "analyzer re-runs after fix"
    ]
  },
  "metric_plan_id": "metric_plan.vince-low-visibility-fix",
  "reference_ids": [
    "doc.architecture.industrial_skill_design",
    "doc.testing.skill_testing_process",
    "doc.metrics.quantitative_skill_metrics",
    "doc.testing.tdd_for_skill_development"
  ]
}

<!-- The project's OWN custom components whose names merely END in
     `-gesture-handler` are NOT Skyline and must NOT be flagged. -->
<app-swipe-gesture-handler bind:swipe="onSwipe">
  <view class="card">a custom component</view>
</app-swipe-gesture-handler>
<my-custom-gesture-handler>
  <view>another custom component</view>
</my-custom-gesture-handler>

<!-- A REAL Skyline gesture handler from the closed set DOES get flagged once. -->
<pan-gesture-handler bind:pan="onPan">
  <view class="drag">drag me</view>
</pan-gesture-handler>

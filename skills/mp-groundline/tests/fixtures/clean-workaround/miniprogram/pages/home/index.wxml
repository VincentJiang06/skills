<!-- clean Skyline-era workarounds; everything should be KEEP, zero rewrite -->
<view class="card">
  <text class="title">Spanning report</text>
  <scroll-view type="list" scroll-y class="feed">
    <view wx:for="{{rows}}" wx:key="id" class="row">
      <text>{{item.label}}</text>
    </view>
  </scroll-view>
  <view class="grid">
    <view wx:for="{{cells}}" wx:key="id" class="cell">{{item}}</view>
  </view>
</view>

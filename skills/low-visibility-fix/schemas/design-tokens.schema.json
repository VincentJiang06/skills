{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "low-visibility-fix/design-tokens",
  "title": "Low-visibility design tokens",
  "type": "object",
  "required": ["version", "contrast", "target_size", "spacing", "font_size"],
  "properties": {
    "version": { "type": "string" },
    "_note": { "type": "string" },
    "contrast": {
      "type": "object",
      "required": ["baseline", "field", "large_text_min_px"],
      "properties": {
        "baseline": { "$ref": "#/$defs/contrast_set" },
        "field": { "$ref": "#/$defs/contrast_set" },
        "large_text_min_px": { "type": "number", "exclusiveMinimum": 0 }
      }
    },
    "target_size": {
      "type": "object",
      "required": ["wcag_min_px", "baseline_px", "field_px", "recommended_px"],
      "additionalProperties": { "type": "number", "exclusiveMinimum": 0 }
    },
    "spacing": {
      "type": "object",
      "required": ["baseline_px", "field_px"],
      "additionalProperties": { "type": "number", "minimum": 0 }
    },
    "font_size": {
      "type": "object",
      "required": ["baseline_px", "field_body_px", "field_critical_px"],
      "additionalProperties": { "type": "number", "exclusiveMinimum": 0 }
    }
  },
  "$defs": {
    "contrast_set": {
      "type": "object",
      "required": ["text", "large_text", "ui"],
      "properties": {
        "text": { "type": "number", "exclusiveMinimum": 1 },
        "large_text": { "type": "number", "exclusiveMinimum": 1 },
        "ui": { "type": "number", "exclusiveMinimum": 1 }
      }
    }
  }
}

{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "low-visibility-fix/eval-cases",
  "title": "Low-visibility-ui-fix eval cases",
  "type": "object",
  "required": ["schema_version", "skill_id", "cases"],
  "properties": {
    "schema_version": { "type": "string" },
    "skill_id": { "type": "string" },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "case_type", "task_zh", "expected_activation", "acceptance_criteria"],
        "properties": {
          "id": { "type": "string" },
          "case_type": {
            "type": "string",
            "enum": ["happy_path", "boundary_path", "negative_path", "adversarial_path"]
          },
          "task_zh": { "type": "string" },
          "fixture": { "type": "string" },
          "expected_activation": {
            "type": "string",
            "enum": ["must_activate", "must_not_activate"]
          },
          "acceptance_criteria": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}

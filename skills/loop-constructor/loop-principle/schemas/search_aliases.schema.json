{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.dev/loop-principle/schemas/search_aliases.schema.json",
  "title": "Loop Principle Search Aliases",
  "type": "object",
  "required": ["schema_version", "alias_set_id", "purpose", "aliases"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string"},
    "alias_set_id": {"type": "string"},
    "purpose": {"type": "string"},
    "aliases": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {"type": "string"},
        "uniqueItems": true
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.dev/loop-principle/schemas/doc_traceability_rules.schema.json",
  "title": "Loop Principle Document Traceability Rules",
  "type": "object",
  "required": ["schema_version", "suite_id", "purpose", "rules"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string"},
    "suite_id": {"type": "string"},
    "purpose": {"type": "string"},
    "rules": {
      "type": "object",
      "required": ["required_headers", "require_all_reference_ids_resolve", "require_all_node_ids_resolve"],
      "additionalProperties": false,
      "properties": {
        "required_headers": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
        "require_all_reference_ids_resolve": {"type": "boolean"},
        "require_all_node_ids_resolve": {"type": "boolean"}
      }
    }
  }
}

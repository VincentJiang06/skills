{
  "schema_version": "1.0.0",
  "gate_set_id": "quality.develop_principle",
  "purpose": "Machine-readable quality gates for skill-principle as a local industrial agent knowledge base.",
  "gates": [
    {
      "id": "quality.graph_single_component",
      "metric_path": "graph.connected_component_sizes",
      "operator": "single_component_equals_path",
      "expected_path": "counts.nodes",
      "required": true
    },
    {
      "id": "quality.no_orphan_long_docs",
      "metric_path": "coverage.long_docs_without_node_reference",
      "operator": "length_equals",
      "expected": 0,
      "required": true
    },
    {
      "id": "quality.all_references_used",
      "metric_path": "coverage.references_without_external_use",
      "operator": "length_equals",
      "expected": 0,
      "required": true
    },
    {
      "id": "quality.generated_index_node_count",
      "metric_path": "graph.adjacency_nodes",
      "operator": "equals_path",
      "expected_path": "counts.nodes",
      "required": true
    },
    {
      "id": "quality.generated_index_edge_count",
      "metric_path": "graph.adjacency_edges",
      "operator": "equals_path",
      "expected_path": "counts.edges",
      "required": true
    },
    {
      "id": "quality.summary_doc_cards_cover_long_docs",
      "metric_path": "counts.summary_doc_cards",
      "operator": "equals_path",
      "expected_path": "counts.long_docs",
      "required": true
    },
    {
      "id": "quality.summary_node_cards_cover_nodes",
      "metric_path": "counts.summary_node_cards",
      "operator": "equals_path",
      "expected_path": "counts.nodes",
      "required": true
    },
    {
      "id": "quality.template_contracts_cover_json_templates",
      "metric_path": "counts.template_contracts",
      "operator": "equals_path",
      "expected_path": "counts.json_template_files",
      "required": true
    },
    {
      "id": "quality.query_case_floor",
      "metric_path": "counts.route_query_cases",
      "operator": "greater_or_equal",
      "expected": 20,
      "required": true
    },
    {
      "id": "quality.compact_query_cases_cover_route_cases",
      "metric_path": "counts.compact_query_cases",
      "operator": "equals_path",
      "expected_path": "counts.route_query_cases",
      "required": true
    },
    {
      "id": "quality.search_token_floor",
      "metric_path": "counts.search_tokens",
      "operator": "greater_or_equal",
      "expected": 1000,
      "required": true
    }
  ]
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.dev/skill-principle/schemas/quality_gate.schema.json",
  "title": "Skill Principle Quality Gate Set",
  "type": "object",
  "required": ["schema_version", "gate_set_id", "purpose", "gates"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string"},
    "gate_set_id": {"type": "string"},
    "purpose": {"type": "string"},
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "metric_path", "operator", "required"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "metric_path": {"type": "string"},
          "operator": {
            "type": "string",
            "enum": ["equals", "equals_path", "greater_or_equal", "length_equals", "single_component_equals_path"]
          },
          "expected": {},
          "expected_path": {"type": "string"},
          "required": {"type": "boolean"}
        }
      }
    }
  }
}

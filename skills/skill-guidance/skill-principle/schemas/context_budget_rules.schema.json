{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.dev/skill-principle/schemas/context_budget_rules.schema.json",
  "title": "Skill Principle Context Budget Rules",
  "type": "object",
  "required": ["schema_version", "suite_id", "purpose", "rules"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string"},
    "suite_id": {"type": "string"},
    "purpose": {"type": "string"},
    "rules": {
      "type": "object",
      "required": [
        "agent_index_max_chars",
        "readme_max_chars",
        "node_summary_zh_max_chars",
        "node_summary_en_max_chars",
        "query_requirement_max_chars",
        "query_expected_total_ids_max",
        "query_generated_limit"
      ],
      "additionalProperties": false,
      "properties": {
        "agent_index_max_chars": {"type": "integer", "minimum": 1},
        "readme_max_chars": {"type": "integer", "minimum": 1},
        "node_summary_zh_max_chars": {"type": "integer", "minimum": 1},
        "node_summary_en_max_chars": {"type": "integer", "minimum": 1},
        "query_requirement_max_chars": {"type": "integer", "minimum": 1},
        "query_expected_total_ids_max": {"type": "integer", "minimum": 1},
        "query_generated_limit": {"type": "integer", "minimum": 1}
      }
    }
  }
}

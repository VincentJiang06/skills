{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.dev/skill-principle/schemas/index.schema.json",
  "title": "Skill Principle Public Index",
  "type": "object",
  "required": ["schema_version", "library_id", "title_zh", "title_en", "purpose_zh", "purpose_en", "root_definition", "coverage", "files", "reference_tiers"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string"},
    "library_id": {"type": "string"},
    "title_zh": {"type": "string"},
    "title_en": {"type": "string"},
    "purpose_zh": {"type": "string"},
    "purpose_en": {"type": "string"},
    "root_definition": {"type": "object"},
    "coverage": {"type": "array"},
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "path", "kind"],
        "additionalProperties": false,
        "properties": {
          "id": {"type": "string"},
          "path": {"type": "string"},
          "kind": {"type": "string"},
          "tags": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        }
      }
    },
    "reference_tiers": {"type": "object"}
  }
}

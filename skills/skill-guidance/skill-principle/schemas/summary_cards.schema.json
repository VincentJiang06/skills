{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.dev/skill-principle/schemas/summary_cards.schema.json",
  "title": "Skill Principle Compressed Summary Cards",
  "type": "object",
  "required": ["schema_version", "generated_from", "docs", "nodes", "coverage"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string"},
    "generated_from": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "docs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["path", "title", "summary_zh", "summary_en", "node_ids", "reference_ids"],
        "additionalProperties": false,
        "properties": {
          "path": {"type": "string"},
          "title": {"type": "string"},
          "summary_zh": {"type": "string"},
          "summary_en": {"type": "string"},
          "node_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "reference_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        }
      }
    },
    "nodes": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["type", "tier", "title_zh", "title_en", "summary_zh", "summary_en", "tags", "doc_ids", "reference_ids"],
        "additionalProperties": false,
        "properties": {
          "type": {"type": "string"},
          "tier": {"type": "integer"},
          "title_zh": {"type": "string"},
          "title_en": {"type": "string"},
          "summary_zh": {"type": "string"},
          "summary_en": {"type": "string"},
          "tags": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "doc_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "reference_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        }
      }
    },
    "coverage": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["title_zh", "docs", "nodes"],
        "additionalProperties": false,
        "properties": {
          "title_zh": {"type": "string"},
          "docs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "nodes": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.dev/skill-principle/schemas/skill_repo_registry.schema.json",
  "title": "Skill Principle Skill Repo Registry",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "registry_id", "purpose", "repos"],
  "properties": {
    "schema_version": {"type": "string"},
    "registry_id": {"const": "references.skill_repos"},
    "purpose": {"type": "string", "minLength": 1},
    "stars_note": {"type": "string"},
    "learning_note": {"type": "string"},
    "repos": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "name", "owner", "repo", "url", "category", "default_branch"],
        "properties": {
          "id": {"type": "string", "pattern": "^repo\\.[a-z0-9_\\-]+$"},
          "name": {"type": "string", "minLength": 1},
          "owner": {"type": "string", "minLength": 1},
          "repo": {"type": "string", "minLength": 1},
          "url": {"type": "string", "format": "uri"},
          "approx_stars": {"type": "integer", "minimum": 0},
          "category": {"type": "string", "enum": ["official", "community", "framework", "collection"]},
          "license": {"type": "string"},
          "default_branch": {"type": "string", "minLength": 1},
          "what_to_learn_zh": {"type": "string"},
          "what_to_learn_en": {"type": "string"},
          "example_skill_paths": {"type": "array", "items": {"type": "string"}},
          "caveat": {"type": "string"}
        }
      }
    }
  }
}

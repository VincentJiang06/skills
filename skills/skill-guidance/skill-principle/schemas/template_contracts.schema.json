{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.dev/skill-principle/schemas/template_contracts.schema.json",
  "title": "Skill Principle Template Contracts",
  "type": "object",
  "required": ["schema_version", "contract_set_id", "purpose", "contracts"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string"},
    "contract_set_id": {"type": "string"},
    "purpose": {"type": "string"},
    "contracts": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "template_id",
          "required_paths",
          "array_paths",
          "reference_id_paths",
          "metric_id_paths",
          "file_id_paths",
          "enum_paths"
        ],
        "additionalProperties": false,
        "properties": {
          "template_id": {"type": "string"},
          "required_paths": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "array_paths": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "reference_id_paths": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "metric_id_paths": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "file_id_paths": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "enum_paths": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["path", "values"],
              "additionalProperties": false,
              "properties": {
                "path": {"type": "string"},
                "values": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
              }
            }
          }
        }
      }
    }
  }
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.dev/skill-principle/schemas/tdd_planning_matrix.schema.json",
  "title": "Skill Principle Skill TDD Planning Matrix",
  "type": "object",
  "required": ["schema_version", "matrix_id", "title_zh", "title_en", "phases", "reference_ids"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {"type": "string"},
    "matrix_id": {"type": "string"},
    "title_zh": {"type": "string"},
    "title_en": {"type": "string"},
    "phases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["phase", "required_outputs", "stop_condition"],
        "additionalProperties": false,
        "properties": {
          "phase": {"type": "string", "enum": ["red", "green", "refactor", "harden"]},
          "required_outputs": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
          "stop_condition": {"type": "string"}
        }
      }
    },
    "reference_ids": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  }
}

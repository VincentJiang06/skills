{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["device", "rig", "category", "candidates", "best_fit", "verdict"],
  "additionalProperties": false,
  "properties": {
    "device": {"type": "string"}, "rig": {"type": "string"}, "category": {"type": "string"},
    "candidates": {"type": "array", "items": {
      "type": "object", "required": ["target", "label", "rms_db", "bias_db", "confidence", "applies_to"],
      "additionalProperties": false,
      "properties": {"target": {"type": "string"}, "label": {"type": "string"},
        "rms_db": {"type": "number"}, "bias_db": {"type": "number"},
        "confidence": {"type": "string"}, "applies_to": {"type": "array", "items": {"type": "string"}}}}},
    "best_fit": {"type": "string"},
    "verdict": {"type": "string"}
  }
}

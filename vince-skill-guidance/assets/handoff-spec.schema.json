{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://local.dev/vince-skill-guidance/handoff-spec.schema.json",
  "title": "vince-skill-guidance handoff spec",
  "description": "Machine-handoff spec emitted by vince-skill-guidance and consumed by vince-skill-engineer.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "generated_by", "target", "intent", "altitude", "altitude_rationale", "scorecard", "overall_readiness", "recommended_design", "prioritized_actions", "handoff"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "generated_by": {"const": "vince-skill-guidance"},
    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "kind", "maturity"],
      "properties": {
        "path": {"type": "string", "minLength": 1},
        "kind": {"enum": ["skill_md", "repo"]},
        "name": {"type": "string"},
        "maturity": {"enum": ["stub", "draft", "mature"]}
      }
    },
    "intent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "in_scope", "out_of_scope", "primary_user", "triggers_observed"],
      "properties": {
        "summary": {"type": "string", "minLength": 1},
        "in_scope": {"type": "array", "items": {"type": "string"}},
        "out_of_scope": {"type": "array", "items": {"type": "string"}},
        "primary_user": {"type": "string"},
        "triggers_observed": {"type": "array", "items": {"type": "string"}}
      }
    },
    "altitude": {"enum": ["lite", "full"]},
    "altitude_rationale": {"type": "string"},
    "scorecard": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["pillar", "status", "score", "evidence", "gaps"],
        "properties": {
          "pillar": {"enum": ["design", "research", "testing", "tdd", "metrics", "low_context_kb", "lifecycle"]},
          "status": {"enum": ["present", "partial", "absent", "na"]},
          "score": {"type": ["integer", "null"], "minimum": 0, "maximum": 2},
          "evidence": {"type": "string"},
          "gaps": {"type": "array", "items": {"type": "string"}}
        }
      }
    },
    "overall_readiness": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ratio", "points", "verdict", "summary"],
      "properties": {
        "ratio": {"type": "number", "minimum": 0, "maximum": 1},
        "points": {"type": "string"},
        "verdict": {"enum": ["draft", "candidate", "industrial"]},
        "summary": {"type": "string"}
      }
    },
    "comparables": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["repo_id", "what_to_borrow"],
        "properties": {
          "repo_id": {"type": "string"},
          "skill_path": {"type": "string"},
          "what_to_borrow": {"type": "string"}
        }
      }
    },
    "recommended_design": {
      "type": "object",
      "additionalProperties": false,
      "required": ["trigger", "protocol", "resources", "evidence_base", "controls", "tests", "metrics", "lifecycle", "adversarial_checklist"],
      "properties": {
        "trigger": {"type": "string"},
        "protocol": {"type": "string"},
        "resources": {"type": "array", "items": {"type": "string"}},
        "evidence_base": {"type": "string"},
        "controls": {"type": "array", "items": {"type": "string"}},
        "tests": {"type": "array", "items": {"type": "string"}},
        "metrics": {"type": "array", "items": {"type": "string"}},
        "lifecycle": {"type": "string"},
        "adversarial_checklist": {"type": "array", "items": {"type": "string"}, "description": "Domain-derived edge inputs the built skill MUST be tested against — derived from the actual input domain, not generic labels (e.g. for a delimiter transform: a key containing the delimiter; for a slugger: CJK/emoji; for a parser: each token/alias + malformed; plus empty/null/collision/idempotency). The engineer binds a passing case to each; the conductor's independent battery attacks each."}
      }
    },
    "prioritized_actions": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "pillar", "action", "priority", "rationale"],
        "properties": {
          "id": {"type": "string"},
          "pillar": {"enum": ["design", "research", "testing", "tdd", "metrics", "low_context_kb", "lifecycle"]},
          "action": {"type": "string"},
          "priority": {"enum": ["P0", "P1", "P2"]},
          "rationale": {"type": "string"}
        }
      }
    },
    "handoff": {
      "type": "object",
      "additionalProperties": false,
      "required": ["next_skill", "blocking_unknowns"],
      "properties": {
        "next_skill": {"const": "vince-skill-engineer"},
        "blocking_unknowns": {"type": "array", "items": {"type": "string"}}
      }
    }
  }
}
